{
  "contract_id": "workflow_to_capability.v1",
  "version": "1.0.0",
  "request": {
    "required_fields": [
      "case_id",
      "workflow_stage",
      "gate_id",
      "required_outcome",
      "policy_context"
    ]
  },
  "response": {
    "required_fields": [
      "capability_id",
      "accepted",
      "required_skills",
      "acceptance_criteria",
      "blockers"
    ]
  },
  "invariants": [
    "accepted == false implies blockers is not empty",
    "accepted == true implies capability_id is not empty"
  ]
}