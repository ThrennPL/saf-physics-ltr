{
  "contract_id": "skill_to_tool.v1",
  "version": "1.0.0",
  "request": {
    "required_fields": [
      "skill_id",
      "operation",
      "payload",
      "validation_rules"
    ]
  },
  "response": {
    "required_fields": [
      "result",
      "diagnostics",
      "working_status",
      "confidence",
      "error_code",
      "stop_flow",
      "escalation_target"
    ],
    "allowed_working_status": [
      "OK",
      "Warning",
      "Blocker"
    ]
  },
  "invariants": [
    "working_status == Blocker implies stop_flow == true",
    "working_status == Blocker implies escalation_target is not empty",
    "confidence in [0,1]"
  ]
}