{
  "contract_id": "capability_to_skill.v1",
  "version": "1.0.0",
  "request": {
    "required_fields": [
      "capability_id",
      "intent",
      "input_artifacts",
      "constraints"
    ]
  },
  "response": {
    "required_fields": [
      "skill_plan",
      "preconditions",
      "execution_order",
      "expected_outputs",
      "fail_conditions"
    ]
  },
  "invariants": [
    "execution_order length >= 1",
    "expected_outputs length >= 1"
  ]
}